package(default_visibility = ["//visibility:public"])

load("@bazel_lib//lib:copy_to_bin.bzl", "copy_to_bin")
load("@kanna_npm//:defs.bzl", "npm_link_all_packages")

npm_link_all_packages(
    name = "node_modules",
)

filegroup(
    name = "srcs",
    srcs = [
        "package.json",
        "tsconfig.json",
    ] + glob([
        "src/**",
    ], exclude = [
        "src/**/*.test.ts",
    ]),
)

copy_to_bin(
    name = "srcs_in_bin",
    srcs = [":srcs"],
)
