package(default_visibility = ["//visibility:public"])

load("@npm//:defs.bzl", "npm_link_all_packages")

npm_link_all_packages(
    name = "node_modules",
)

filegroup(
    name = "srcs",
    srcs = glob(
        ["**"],
        exclude = [
            ".DS_Store",
            "**/.DS_Store",
            ".turbo/**",
            "dist/**",
            "node_modules/**",
        ],
    ),
)
