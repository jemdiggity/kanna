+fn zig_optimize_mode() -> &'static str {
+    if env::var("DEBUG")
+        .ok()
+        .is_some_and(|value| value.eq_ignore_ascii_case("true"))
+    {
+        return "Debug";
+    }
+
+    match env::var("OPT_LEVEL").as_deref() {
+        Ok("0") => "Debug",
+        Ok(_) => "ReleaseFast",
+        Err(_) => "ReleaseFast",
+    }
 }
 
