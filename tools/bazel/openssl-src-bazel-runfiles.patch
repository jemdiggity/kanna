 use std::process::Command;
 
 pub fn source_dir() -> PathBuf {
-    Path::new(env!("CARGO_MANIFEST_DIR")).join("openssl")
+    let manifest_dir = PathBuf::from(env!("CARGO_MANIFEST_DIR"));
+    let direct = manifest_dir.join("openssl");
+    if direct.exists() {
+        return direct;
+    }
+
+    let repo_name = manifest_dir.file_name().map(PathBuf::from);
+    let cwd = env::current_dir().ok();
+
+    if let (Some(repo_name), Some(cwd)) = (repo_name, cwd) {
+        let candidates = [
+            cwd.join(&repo_name).join("openssl"),
+            cwd.parent()
+                .map(|parent| parent.join(&repo_name).join("openssl"))
+                .unwrap_or_else(|| cwd.join(&repo_name).join("openssl")),
+            cwd.join("external").join(&repo_name).join("openssl"),
+            cwd.parent()
+                .map(|parent| parent.join("external").join(&repo_name).join("openssl"))
+                .unwrap_or_else(|| cwd.join("external").join(&repo_name).join("openssl")),
+        ];
+
+        for candidate in candidates {
+            if candidate.exists() {
+                return candidate;
+            }
+        }
+    }
+
+    direct
 }
 
