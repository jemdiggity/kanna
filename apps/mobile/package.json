{
  "name": "@kanna/mobile",
  "private": true,
  "version": "0.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "expo start",
    "ios": "expo run:ios",
    "gen:terminal-assets": "node ./scripts/generate-terminal-assets.mjs",
    "test:e2e": "pnpm exec tsx ./e2e/run.ts",
    "test:e2e:smoke": "pnpm exec tsx ./e2e/run.ts smoke",
    "test:e2e:preflight": "pnpm exec tsx ./e2e/preflight.ts",
    "test:e2e:appium:install-xcuitest": "pnpm exec tsx ./e2e/helpers/appium.ts install-xcuitest",
    "test:e2e:appium:start": "pnpm exec tsx ./e2e/helpers/appium.ts start",
    "test": "sh -c 'if [ \"$1\" = \"--\" ]; then shift; fi; if [ \"$1\" = \"--runInBand\" ]; then shift; fi; exec pnpm dlx vitest run \"$@\"' --",
    "typecheck": "pnpm exec tsc --noEmit",
    "android": "expo run:android"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^3.0.2",
    "@react-navigation/bottom-tabs": "^7.0.0",
    "@react-navigation/native": "^7.0.0",
    "@xterm/addon-fit": "0.12.0-beta.195",
    "@xterm/xterm": "6.1.0-beta.195",
    "expo": "~53.0.0",
    "react": "19.0.0",
    "react-native": "0.79.2",
    "react-native-webview": "13.13.5"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "appium": "^2.19.0",
    "tsx": "^4.21.0",
    "webdriverio": "^9.20.0"
  }
}
