{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kanna",
  "version": "0.0.32",
  "identifier": "build.kanna",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "theme": "Dark",
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "infoPlist": "Info.plist"
    },
    "externalBin": [
      "binaries/kanna-daemon",
      "binaries/kanna-cli",
      "binaries/kanna-terminal-recovery"
    ],
    "resources": {
      "../../../.kanna/agents/": ".kanna/agents/",
      "../../../.kanna/pipelines/": ".kanna/pipelines/",
      "../../../.kanna/tasks/": ".kanna/tasks/"
    },
    "icon": []
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "sql": {}
  }
}
