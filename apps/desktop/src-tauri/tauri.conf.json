{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kanna",
  "version": "0.0.44",
  "identifier": "build.kanna",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "theme": "Dark",
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "macOS": {
      "infoPlist": "Info.plist"
    },
    "externalBin": [
      "binaries/kanna-daemon",
      "binaries/kanna-cli",
      "binaries/kanna-mcp",
      "binaries/kanna-terminal-recovery",
      "binaries/kanna-server",
      "binaries/kanna-task-transfer"
    ],
    "resources": {
      "../../../.kanna/agents/": ".kanna/agents/",
      "../../../.kanna/pipelines/": ".kanna/pipelines/",
      "../../../.kanna/tasks/": ".kanna/tasks/"
    },
    "icon": [
      "icons/icon.icns"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "sql": {},
    "updater": {
      "pubkey": "",
      "endpoints": [
        "https://github.com/jemdiggity/kanna/releases/latest/download/latest.json"
      ]
    }
  }
}
