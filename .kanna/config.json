{
  "$schema": "https://schemas.kanna.build/config.schema.json",
  "setup": [
    "/bin/sh ./scripts/setup-worktree.sh",
    "pnpm install"
  ],
  "teardown": ["/bin/bash ./scripts/dev.sh stop -k", "/bin/bash ./scripts/clean.sh --all"],
  "test": ["pnpm test"],
  "workspace": {
    "path": {
      "prepend": ["./node_modules/.bin"]
    }
  },
  "ports": {
    "KANNA_DEV_PORT": 1420,
    "KANNA_WEBDRIVER_PORT": 4445,
    "KANNA_RELAY_PORT": 9080,
    "KANNA_MOBILE_SERVER_PORT": 48120,
    "KANNA_MOBILE_PORT": 8081,
    "KANNA_APPIUM_PORT": 4723,
    "KANNA_TRANSFER_PORT": 4455
  }
}
